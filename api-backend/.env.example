# JHCIS Summary Centralization API - Environment Configuration

# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jhcis_central
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# For MySQL/MariaDB, adjust DB_PORT to 3306 and ensure driver is configured

# ============================================
# Security Configuration
# ============================================
# CORS origin (use specific domain in production, e.g., https://jhcis.go.th)
CORS_ORIGIN=*

# API Key secret salt (for additional hashing if needed)
API_KEY_SALT=your_random_salt_here

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# Production Settings
# ============================================
# Set to 'production' in production environment
NODE_ENV=production

# Trusted proxies (comma-separated IPs)
TRUSTED_PROXIES=127.0.0.1,10.0.0.1
