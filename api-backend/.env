# JHCIS Summary Centralization API - Environment Configuration

# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# Server Configuration
# ============================================
PORT=9021
NODE_ENV=development

# ============================================
# Database Configuration (MariaDB)
# ============================================
DB_CLIENT=mysql
DB_HOST=localhost
DB_PORT=3333
DB_NAME=jhcis_central
DB_USER=root
DB_PASSWORD=12345678

# ============================================
# Security Configuration
# ============================================
# CORS origin (use specific domain in production, e.g., https://jhcis.go.th)
CORS_ORIGIN=*

# API Key secret salt (for additional hashing if needed)
API_KEY_SALT=your_random_salt_here

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# Production Settings
# ============================================
# Set NODE_ENV=production when deploying
TRUSTED_PROXIES=127.0.0.1,10.0.0.1
ADMIN_EMAIL=admin@ubonlocal.go.th
ADMIN_PASSWORD=admin123
ADMIN_TOKEN_SECRET=jhcis_admin_token_secret_2026
ADMIN_TOKEN_TTL_SECONDS=28800
